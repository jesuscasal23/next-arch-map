{
  "name": "next-arch-map",
  "version": "0.1.1",
  "description": "Static analyzer that builds a multi-layer architecture graph for Next.js-style apps.",
  "type": "module",
  "bin": {
    "next-arch-map": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js"
    }
  },
  "files": [
    "dist",
    "viewer",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "dev": "node dist/cli.js dev"
  },
  "keywords": [
    "nextjs",
    "architecture",
    "graph",
    "static-analysis",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jesuscasal23/next-arch-map"
  },
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
